generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "admin", "user"
  description String?
  permissions Json     @default("[]") // Array of permission strings
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique // Auth requires email
  password  String   // Hashed password
  name      String?
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  chats     Chat[]
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chat {
  id        String    @id @default(cuid())
  title     String? // Sohbetin başlığı
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String // "user", "assistant" veya "system"
  content   String // Mesajın içeriği
  createdAt DateTime @default(now())
}

model Document {
  id        String                      @id @default(cuid())
  content   String // RAG için metin (chunk) içeriği
  embedding Unsupported("vector(768)")? // Vektör verisi
  metadata  Json? // Ekstra bilgiler (hangi dosyadan geldi vb.)
  createdAt DateTime                    @default(now())
}
